# ── Source tab files ────────────────────────────────────────────────────────
# The classtab.org library is large (~2 300 pieces, MIDI + text).
# Download the zip from https://www.classtab.org and unzip into tab/.
# See README.md for setup instructions.
tab/*
!tab/.gitkeep

# ── Generated output ─────────────────────────────────────────────────────────
# Regenerated by `python pipeline/main.py` — do not commit
output/

# ── macOS metadata ───────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo

# ── Editor / tooling ─────────────────────────────────────────────────────────
.venv/
build/
dist/
*.egg-info/
.pytest_cache/
